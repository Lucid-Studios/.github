{
  "schema": "sli.scar.adapter_contract.v0.1.0",
  "description": "External inference harness adapter contract for SCAR artifacts.",
  "input": {
    "sheaf_schema": "gel.sheaf.v0.2.0",
    "required_fields": ["surface", "sheaf.entities", "sheaf.events", "sheaf.scope"]
  },
  "outputs": {
    "bias_spec": "sli.scar.bias_spec.v0.1.0",
    "head_gate": "sli.scar.head_gate.v0.1.0",
    "kv_anchor": "sli.scar.kv_anchor.v0.1.0",
    "telemetry": "sli.scar.telemetry.v0.1.0"
  },
  "errors": {
    "fatal": ["schema_invalid", "anchors_missing", "unparseable_json"],
    "warning": ["coverage_low", "glue_inactive", "node_unmapped"]
  }
}
