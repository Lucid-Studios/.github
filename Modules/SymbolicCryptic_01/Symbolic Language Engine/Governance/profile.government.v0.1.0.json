{
  "schema": "oan.operator_profile.v0.1.0",
  "profile_id": "profile.government.v0.1.0",
  "version": "v0.1.0",
  "tier": "government",
  "taxonomy_class": "governmental",
  "inherits": [
    "profile.enterprise.v0.1.0"
  ],
  "explanation_policy": "directive",
  "autonomy_policy": "locked_procedural",
  "verification_policy": {
    "require_signed_governance_contracts": true,
    "require_signed_repo_attachments": true,
    "require_deterministic_build": true,
    "require_profile_signature": true
  },
  "telemetry_policy": {
    "mode": "forensic",
    "detail_level": "forensic",
    "forensic_mode": true
  },
  "repo_attachment_policy": {
    "allowed_repo_classes": [
      "internal",
      "verified_external",
      "institutional_signed"
    ],
    "forbidden_unsigned": true,
    "require_multisig_for_government": true
  },
  "security_posture": {
    "mode": "adversarial",
    "adversarial_assumption": true
  },
  "seal_admission_policy": {
    "required": true,
    "strict": true
  },
  "allowed_careers": [
    "career.mother_prime",
    "career.father_cryptic",
    "career.steward"
  ],
  "allowed_jobs": [
    "job.prime_guard",
    "job.cryptic_guard",
    "job.sanctuary_watch"
  ],
  "allowed_trades": [
    "trade.audit",
    "trade.security_sentinel",
    "trade.telemetry"
  ],
  "allowed_interface_permissions": [
    "prime_summary",
    "policy_read",
    "telemetry_emit",
    "cryptic_summary",
    "lease_issue",
    "watchdog_control",
    "duplex_report"
  ],
  "allowed_tool_permissions": [
    "tool.audit_reader",
    "tool.telemetry_writer",
    "tool.cryptic_watcher",
    "tool.lease_manager",
    "tool.watchdog",
    "tool.duplex_writer"
  ],
  "required_exposure_policy": {
    "prime_mode": "pointer_only_cryptic",
    "cryptic_payload_in_prime_forbidden": true
  }
}
