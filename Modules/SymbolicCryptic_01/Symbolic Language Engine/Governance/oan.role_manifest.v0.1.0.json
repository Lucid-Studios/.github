{
  "schema": "oan.role_manifest.v0.1.0",
  "policy_version": "v0.1.0",
  "roles": [
    {
      "career_id": "career.mother_prime",
      "job_id": "job.prime_guard",
      "job_class": "prime_steward",
      "allowed_trades": ["trade.audit", "trade.telemetry"],
      "tsa_requirements": ["tsa.audit.cert", "tsa.telemetry.cert"],
      "interface_permissions": ["prime_summary", "policy_read", "telemetry_emit"],
      "tool_permissions": ["tool.audit_reader", "tool.telemetry_writer"],
      "evaluation_triggers": ["on_boot", "on_policy_change"]
    },
    {
      "career_id": "career.father_cryptic",
      "job_id": "job.cryptic_guard",
      "job_class": "cryptic_steward",
      "allowed_trades": ["trade.security_sentinel", "trade.telemetry"],
      "tsa_requirements": ["tsa.security.cert", "tsa.telemetry.cert"],
      "interface_permissions": ["cryptic_summary", "policy_read", "telemetry_emit"],
      "tool_permissions": ["tool.cryptic_watcher", "tool.telemetry_writer"],
      "evaluation_triggers": ["on_boot", "on_incident"]
    },
    {
      "career_id": "career.steward",
      "job_id": "job.sanctuary_watch",
      "job_class": "sanctuary_orchestrator",
      "allowed_trades": ["trade.audit", "trade.security_sentinel", "trade.telemetry"],
      "tsa_requirements": ["tsa.ops.cert"],
      "interface_permissions": ["lease_issue", "watchdog_control", "duplex_report"],
      "tool_permissions": ["tool.lease_manager", "tool.watchdog", "tool.duplex_writer"],
      "evaluation_triggers": ["on_boot", "on_stall_detected", "on_recovery"]
    }
  ],
  "anti_bleed": {
    "trades_may_not_modify_career_identity": true,
    "trades_may_not_modify_career_charter": true,
    "trades_may_not_modify_exposure_policy": true,
    "trades_may_not_modify_oe_invariants": true
  }
}
