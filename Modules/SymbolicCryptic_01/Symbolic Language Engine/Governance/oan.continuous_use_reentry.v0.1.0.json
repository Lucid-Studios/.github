{
  "schema": "oan.continuous_use_reentry.v0.1.0",
  "policy_id": "sanctuary.reentry.v0.1.0",
  "version": "v0.1.0",
  "requires_prior_founding": true,
  "full_replay_required": true,
  "checks": [
    "chain_head_match",
    "founding_constituted",
    "bonded_operator_match",
    "profile_signature_verified",
    "role_preconditions_met"
  ],
  "anti_downgrade_required": true,
  "denial_reason_namespaces": [
    "REENTRY_*",
    "POLICY_*"
  ]
}
