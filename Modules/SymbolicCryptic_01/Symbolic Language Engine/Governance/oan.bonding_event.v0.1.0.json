{
  "schema": "oan.bonding_event.v0.1.0",
  "description": "Append-only runtime witness event. Hash-linked chain; not per-event signed in v0.1.",
  "required": [
    "sequence",
    "event_id",
    "prev_event_hash",
    "event_hash",
    "oe_header_ref",
    "career_id",
    "job_id",
    "lease"
  ],
  "lease_required": [
    "lease_id",
    "issuer_role",
    "subject_role",
    "capability_ids",
    "tool_permissions",
    "scope",
    "expires_policy",
    "revocation_policy",
    "issued_at"
  ],
  "integrity": {
    "append_only": true,
    "hash_linked": true,
    "per_event_signature_required": false,
    "checkpoint_signing": "v0.2"
  }
}
