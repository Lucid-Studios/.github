{
  "schema": "oan.first_boot_contract.v0.1.0",
  "contract_id": "sanctuary.first_boot.v0.1.0",
  "version": "v0.1.0",
  "state_machine": {
    "states": [
      "UNFORMED",
      "FOUNDING",
      "BONDED",
      "READY",
      "RESTRICTED"
    ],
    "valid_transitions": [
      { "from": "UNFORMED", "to": "FOUNDING" },
      { "from": "FOUNDING", "to": "BONDED" },
      { "from": "BONDED", "to": "READY" },
      { "from": "UNFORMED", "to": "RESTRICTED" },
      { "from": "FOUNDING", "to": "RESTRICTED" },
      { "from": "BONDED", "to": "RESTRICTED" }
    ]
  },
  "requires": {
    "operator_identity_record": true,
    "operator_bonding_set": true,
    "operator_selection_manifest": true,
    "authentication_chain": true,
    "data_protection_policy": true
  },
  "anti_downgrade": {
    "profile_constraints_monotonic": true,
    "protection_depth_monotonic": true,
    "seal_admission_monotonic": true,
    "anti_bleed_monotonic": true,
    "exposure_policy_monotonic": true
  },
  "founder_succession_transfer_out_of_scope": true,
  "denial_reason_namespaces": [
    "FOUNDING_*",
    "POLICY_*"
  ]
}
