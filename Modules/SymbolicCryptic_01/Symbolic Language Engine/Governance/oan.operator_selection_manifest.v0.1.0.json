{
  "schema": "oan.operator_selection_manifest.v0.1.0",
  "manifest_id": "operator.selection.manifest.v0.1.0",
  "version": "v0.1.0",
  "profile_id": "profile.enterprise.v0.1.0",
  "tier": "enterprise",
  "taxonomy_class": "corporate",
  "inherits": [
    "profile.personal.v0.1.0"
  ],
  "explanation_policy": "operational",
  "autonomy_policy": "policy_bound",
  "verification_policy": {
    "require_signed_governance_contracts": true,
    "require_signed_repo_attachments": true,
    "require_deterministic_build": true,
    "require_profile_signature": true
  },
  "telemetry_policy": {
    "mode": "operational",
    "detail_level": "high",
    "forensic_mode": false
  },
  "repo_attachment_policy": {
    "allowed_repo_classes": [
      "internal",
      "verified_external"
    ],
    "forbidden_unsigned": true,
    "require_multisig_for_government": false
  },
  "security_posture": {
    "mode": "compliance",
    "adversarial_assumption": true
  },
  "seal_admission_policy": {
    "required": false,
    "strict": false
  },
  "allowed_careers": [
    "career.mother_prime",
    "career.father_cryptic",
    "career.steward"
  ],
  "allowed_jobs": [
    "job.prime_guard",
    "job.cryptic_guard",
    "job.sanctuary_watch"
  ],
  "allowed_trades": [
    "trade.audit",
    "trade.security_sentinel",
    "trade.telemetry"
  ],
  "allowed_interface_permissions": [
    "prime_summary",
    "policy_read",
    "telemetry_emit",
    "cryptic_summary",
    "lease_issue",
    "watchdog_control",
    "duplex_report"
  ],
  "allowed_tool_permissions": [
    "tool.audit_reader",
    "tool.telemetry_writer",
    "tool.cryptic_watcher",
    "tool.lease_manager",
    "tool.watchdog",
    "tool.duplex_writer"
  ],
  "required_exposure_policy": {
    "prime_mode": "pointer_only_cryptic",
    "cryptic_payload_in_prime_forbidden": true
  },
  "denial_reason_codes": [
    "ROLE_NOT_ALLOWED",
    "TRADE_NOT_ALLOWED",
    "UNSIGNED_REPO_DENIED",
    "SEAL_ADMISSION_REQUIRED",
    "EXPOSURE_POLICY_WEAKENING_DENIED",
    "TOOL_PERMISSION_OUT_OF_SCOPE"
  ]
}
