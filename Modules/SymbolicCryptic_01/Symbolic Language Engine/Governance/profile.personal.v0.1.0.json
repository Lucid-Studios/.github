{
  "schema": "oan.operator_profile.v0.1.0",
  "profile_id": "profile.personal.v0.1.0",
  "version": "v0.1.0",
  "tier": "personal",
  "taxonomy_class": "individual",
  "inherits": [],
  "explanation_policy": "tutorial",
  "autonomy_policy": "suggestive",
  "verification_policy": {
    "require_signed_governance_contracts": false,
    "require_signed_repo_attachments": false,
    "require_deterministic_build": true,
    "require_profile_signature": false
  },
  "telemetry_policy": {
    "mode": "transparent",
    "detail_level": "verbose",
    "forensic_mode": false
  },
  "repo_attachment_policy": {
    "allowed_repo_classes": [
      "personal",
      "community",
      "internal",
      "verified_external"
    ],
    "forbidden_unsigned": false,
    "require_multisig_for_government": false
  },
  "security_posture": {
    "mode": "safety",
    "adversarial_assumption": false
  },
  "seal_admission_policy": {
    "required": false,
    "strict": false
  },
  "allowed_careers": [
    "career.mother_prime",
    "career.steward"
  ],
  "allowed_jobs": [
    "job.prime_guard",
    "job.sanctuary_watch"
  ],
  "allowed_trades": [
    "trade.audit",
    "trade.telemetry"
  ],
  "allowed_interface_permissions": [
    "prime_summary",
    "policy_read",
    "telemetry_emit",
    "lease_issue",
    "watchdog_control",
    "duplex_report"
  ],
  "allowed_tool_permissions": [
    "tool.audit_reader",
    "tool.telemetry_writer",
    "tool.lease_manager",
    "tool.watchdog",
    "tool.duplex_writer"
  ],
  "required_exposure_policy": {
    "prime_mode": "pointer_only_cryptic",
    "cryptic_payload_in_prime_forbidden": true
  }
}
