{
  "schema": "gel.reserved_index.v0.2.0",
  "description": "Canonical reserved token index for assignment blocking and parser literal handling.",
  "policy": {
    "assignment": "hard_ban",
    "parsing": "allow_literals_only",
    "enforcement": "Token-level checks for both single-glyph and multi-character reserved entries."
