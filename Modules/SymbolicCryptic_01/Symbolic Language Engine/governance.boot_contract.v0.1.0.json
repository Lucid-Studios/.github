{
  "schema": "governance.boot_contract.v0.1.0",
  "description": "Duplex governance boot contract for Mother/Father/Steward agents after Seed load.",
  "boot_sequence": [
    "SEED_LOADED",
    "MOTHER_BOOT",
    "FATHER_BOOT",
    "STEWARD_BOOT",
    "HEARTBEAT_STABLE",
    "READY"
  ],
  "state_machine": {
    "states": ["INIT", "SEED_READY", "AGENTS_BOOTING", "WATCHING", "STALLED", "RECOVERING", "HALTED"],
    "transitions": [
      { "from": "INIT", "to": "SEED_READY", "on": "seed_loaded" },
      { "from": "SEED_READY", "to": "AGENTS_BOOTING", "on": "boot_start" },
      { "from": "AGENTS_BOOTING", "to": "WATCHING", "on": "boot_complete" },
      { "from": "WATCHING", "to": "STALLED", "on": "stall_detected" },
      { "from": "STALLED", "to": "RECOVERING", "on": "recovery_start" },
      { "from": "RECOVERING", "to": "WATCHING", "on": "recovery_ok" },
      { "from": "RECOVERING", "to": "HALTED", "on": "recovery_failed" }
    ]
  },
  "stall_detection": {
    "heartbeat_timeout_seconds": 45,
    "max_missed_heartbeats": 3,
    "max_recovery_attempts": 2
  },
  "action_policy": {
    "Mother": {
      "allowed": ["observe", "summarize_prime", "escalate"],
      "denied": ["mutate_indices", "rewrite_contracts"]
    },
    "Father": {
      "allowed": ["observe", "summarize_cryptic", "escalate"],
      "denied": ["mutate_indices", "rewrite_contracts"]
    },
    "Steward": {
      "allowed": ["watchdog", "restart_agent", "emit_duplex_report"],
      "denied": ["mutate_rootindex", "disable_reserved_rules"]
    }
  },
  "duplex_reporting": {
    "prime_channel": "executive_summary",
    "cryptic_channel": "detailed_trace",
    "same_event_stream_required": true
  }
}
