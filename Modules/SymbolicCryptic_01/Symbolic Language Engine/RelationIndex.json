{
  "schema": "gel.relation_index.v0.2.0",
  "notes": [
    "All relation symbols must be unique across PrefixIndex, RootIndex, SuffixIndex, OperatorIndex, RelationIndex, and GrammarSheafIndex.",
    "Do not assign symbols or relation keys that appear in Reserved[] or assignment_rules.reserved.meta/control.",
    "Relations represent semantic edges and intentionally avoid formal-logic glyph usage."
  ],
  "relations": {
    "IN": { "symbol": "⧉⟐", "gloss": "Containment / location: A IN B." },
    "ON": { "symbol": "⧉⟡", "gloss": "Support / surface relation: A ON B." },
    "AT": { "symbol": "⧉⟢", "gloss": "Point location / event locale: A AT B." },
    "WITH": { "symbol": "⧉⟣", "gloss": "Accompaniment / co-participation: A WITH B." },
    "HAS": { "symbol": "⧉⟠", "gloss": "Possession / attribute holding: A HAS B." },
    "OF": { "symbol": "⧉⟤", "gloss": "Genitive / belonging relation." },
    "ABOUT": { "symbol": "⧉⟥", "gloss": "Topic relation: A ABOUT B." },
    "FOR": { "symbol": "⧉⟦", "gloss": "Benefactive / purpose relation." },
    "PART_OF": { "symbol": "⧉⟧", "gloss": "Mereology: A PART_OF B." },
    "HAS_PART": { "symbol": "⧉⟨", "gloss": "Inverse mereology: A HAS_PART B." },
    "MEMBER_OF": { "symbol": "⧉⟩", "gloss": "Membership relation." },
    "HAS_MEMBER": { "symbol": "⧉⟪", "gloss": "Inverse membership relation." },
    "INSTANCE_OF": { "symbol": "⧉⟫", "gloss": "Typing relation: A INSTANCE_OF Type." },
    "SUBTYPE_OF": { "symbol": "⧉⟬", "gloss": "Type hierarchy: A SUBTYPE_OF B." },
    "EQUIV_TO": { "symbol": "⧉⟭", "gloss": "Semantic equivalence relation." },
    "SAME_AS": { "symbol": "⧉⟮", "gloss": "Identity persistence / co-reference relation." },
    "CAUSES": { "symbol": "⧉⟯", "gloss": "Causal edge: A CAUSES B." },
    "ENABLES": { "symbol": "⧉⟰", "gloss": "Enabling edge: A ENABLES B." },
    "PREVENTS": { "symbol": "⧉⟱", "gloss": "Blocking edge: A PREVENTS B." },
    "IMPLIES": { "symbol": "⧉⟲", "gloss": "Semantic implication edge (pre-math)." },
    "BEFORE": { "symbol": "⧉⟳", "gloss": "Temporal ordering: A BEFORE B." },
    "AFTER": { "symbol": "⧉⟴", "gloss": "Temporal ordering: A AFTER B." },
    "DURING": { "symbol": "⧉⟵", "gloss": "Temporal overlap: A DURING B." },
    "OVERLAPS": { "symbol": "⧉⟶", "gloss": "Temporal overlap (symmetric-ish)." },
    "AGENT_OF": { "symbol": "⧉⟷", "gloss": "Role relation: entity is agent of event." },
    "PATIENT_OF": { "symbol": "⧉⟸", "gloss": "Role relation: entity is patient/theme of event." },
    "TARGET_OF": { "symbol": "⧉⟹", "gloss": "Role relation: entity is target of event." },
    "INSTRUMENT_OF": { "symbol": "⧉⟺", "gloss": "Role relation: entity is instrument of event." },
    "REFERS_TO": { "symbol": "⧉⟻", "gloss": "Reference edge (anaphora, citation, pointer)." },
    "DERIVES_FROM": { "symbol": "⧉⟼", "gloss": "Derivation provenance relation." },
    "MAPS_TO": { "symbol": "⧉⟽", "gloss": "Representation mapping relation." },
    "ALIAS_OF": { "symbol": "⧉⟾", "gloss": "Alias/canonical relation." }
  }
}
