{
  "schema": "gel.sheaf.v0.2.0",
  "description": "Canonical middle-stratum structure that bridges lexical roots to symbolic and formal layers.",
  "required": [
    "schema",
    "surface",
    "sheaf"
  ],
  "sheaf": {
    "required": [
      "entities",
      "states",
      "events",
      "scope"
    ],
    "entities": {
      "type": "array",
      "items": {
        "id": "string",
        "root": "string",
        "symbol": "string (optional; from RootIndex)",
        "type": "string (optional)"
      }
    },
    "states": {
      "type": "array",
      "items": {
        "target": "entity_id",
        "op": "STATE",
        "value": "string",
        "value_symbol": "string (optional; from RootIndex or OperatorIndex)"
      }
    },
    "events": {
      "type": "array",
      "items": {
        "id": "string (optional)",
        "op": "ACT",
        "verb": "string",
        "verb_symbol": "string (optional; from RootIndex)",
        "agent": "entity_id",
        "target": "entity_id (optional)",
        "instrument": "entity_id (optional)"
      }
    },
    "relations": {
      "type": "array",
      "optional": true,
      "items": {
        "source": "node_id",
        "relation": "RelationIndex key",
        "target": "node_id"
      }
    },
    "scope": {
      "required": [
        "tense",
        "modality"
      ],
      "fields": {
        "tense": "past | present | future | mixed",
        "modality": "assert | query | imperative | conditional",
        "evidential": "observed | reported | inferred | assumed (optional)"
      }
    },
    "metadata": {
      "optional": true,
      "fractional_encoding": "x/y/z triplets allowed only in metadata fields",
      "fields": {
        "confidence": "x/y/z (optional)",
        "event_mode": "x/y/z (optional)",
        "temporal_mode": "x/y/z (optional)",
        "context_mode": "x/y/z (optional)"
      }
    }
  },
  "examples": {
    "encode": {
      "surface": "The firefighter entered the burning building.",
      "sheaf": {
        "entities": [
          { "id": "e1", "root": "firefighter", "symbol": "⍙f..." },
          { "id": "e2", "root": "building", "symbol": "⍙b..." }
        ],
        "states": [
          {
            "target": "e2",
            "op": "STATE",
            "value": "burning"
          }
        ],
        "events": [
          {
            "id": "ev1",
            "op": "ACT",
            "verb": "enter",
            "agent": "e1",
            "target": "e2"
          }
        ],
        "relations": [
          { "source": "e1", "relation": "AGENT_OF", "target": "ev1" },
          { "source": "e2", "relation": "TARGET_OF", "target": "ev1" }
        ],
        "scope": {
          "tense": "past",
          "modality": "assert"
        },
        "metadata": {
          "confidence": "1/0/0",
          "event_mode": "0/1/0",
          "temporal_mode": "1/0/0",
          "context_mode": "1/1/0"
        }
      }
    },
    "decode": {
      "semantic_summary": "A firefighter performed an entering event targeting a building in a burning state.",
      "surface_reconstruction": "The firefighter entered the burning building."
    }
  }
}
