{
  "schema": "gel.operator_index.v0.2.0",
  "notes": [
    "All operator symbols must be unique across PrefixIndex, RootIndex, SuffixIndex, OperatorIndex, RelationIndex, and GrammarSheafIndex.",
    "No symbol or operator key may be assigned if it appears in Reserved[] or in assignment_rules.reserved.meta/control.",
    "Symbols are semantic-layer operators and are not formal-logic operators."
  ],
  "operators": {
    "ACT": { "symbol": "⧗⟐", "gloss": "Event/action operator. Declares an event node." },
    "STATE": { "symbol": "⧗⟡", "gloss": "State/property operator. Declares a state node." },
    "REL": { "symbol": "⧗⟢", "gloss": "Relation operator. Declares a typed relation edge." },
    "ROLE": { "symbol": "⧗⟣", "gloss": "Role binding operator (agent, patient, instrument, etc.)." },
    "BIND": { "symbol": "⥁⟐", "gloss": "Binds an identifier to an entity/event/state (variable binding)." },
    "REF": { "symbol": "⥁⟡", "gloss": "Reference operator to a prior node or anchor." },
    "SCOPE": { "symbol": "⥁⟢", "gloss": "Scope boundary operator (clause, quantifier scope, nesting)." },
    "CTX": { "symbol": "⥁⟣", "gloss": "Context operator (frame: discourse, scene, domain)." },
    "TIME": { "symbol": "⧈⟐", "gloss": "Temporal anchoring operator (before/after/during, tense tags)." },
    "ASPECT": { "symbol": "⧈⟡", "gloss": "Aspect operator (ongoing/completed/habitual)." },
    "MODAL": { "symbol": "⧈⟢", "gloss": "Modality operator (possible/necessary/obligatory/intended)." },
    "EVID": { "symbol": "⧈⟣", "gloss": "Evidential operator (observed/reported/inferred/assumed)." },
    "CAUSE": { "symbol": "⧜⟐", "gloss": "Causal operator connecting cause and effect." },
    "ENABLE": { "symbol": "⧜⟡", "gloss": "Enabling-condition operator." },
    "PREVENT": { "symbol": "⧜⟢", "gloss": "Prevention/inhibition operator." },
    "GOAL": { "symbol": "⧜⟣", "gloss": "Goal/intent operator." },
    "COMPARE": { "symbol": "⧟⟐", "gloss": "Comparison operator." },
    "NEG": { "symbol": "⧟⟡", "gloss": "Semantic negation (pre-math layer)." },
    "ASSERT": { "symbol": "⧟⟢", "gloss": "Assertion speech-act operator." },
    "QUERY": { "symbol": "⧟⟣", "gloss": "Question/interrogative operator." },
    "DEF": { "symbol": "⧠⟐", "gloss": "Definition operator." },
    "TYPE": { "symbol": "⧠⟡", "gloss": "Typing operator." },
    "INSTANCE": { "symbol": "⧠⟢", "gloss": "Instance declaration operator." },
    "PART": { "symbol": "⧠⟣", "gloss": "Part/whole operator." },
    "MAP": { "symbol": "⧗⟠", "gloss": "Representation mapping operator." },
    "TRANS": { "symbol": "⧗⟤", "gloss": "Transformation operator." },
    "EQUIV": { "symbol": "⥁⟠", "gloss": "Semantic equivalence operator." },
    "ID": { "symbol": "⥁⟤", "gloss": "Identity persistence operator." },
    "PACK": { "symbol": "⧈⟠", "gloss": "Sheaf packing operator." },
    "UNPACK": { "symbol": "⧈⟤", "gloss": "Sheaf unpacking operator." }
  }
}
