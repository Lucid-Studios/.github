{
  "schema": "gel.grammar_sheaf_index.v0.2.0",
  "notes": [
    "GrammarSheaf symbols mark structure, scope, argument framing, and clause boundaries.",
    "Symbols must be unique across PrefixIndex, RootIndex, SuffixIndex, OperatorIndex, RelationIndex, and GrammarSheafIndex.",
    "Do not assign any symbol or marker key that is present in Reserved[] or assignment_rules.reserved.meta/control."
  ],
  "markers": {
    "SHEAF_OPEN": { "symbol": "⧆⟐", "gloss": "Start of sheaf frame." },
    "SHEAF_CLOSE": { "symbol": "⧆⟡", "gloss": "End of sheaf frame." },
    "CLAUSE_OPEN": { "symbol": "⧆⟢", "gloss": "Start of clause scope." },
    "CLAUSE_CLOSE": { "symbol": "⧆⟣", "gloss": "End of clause scope." },
    "PHRASE_OPEN": { "symbol": "⧆⟠", "gloss": "Start of phrase scope." },
    "PHRASE_CLOSE": { "symbol": "⧆⟤", "gloss": "End of phrase scope." },
    "ARG_OPEN": { "symbol": "⧆⟥", "gloss": "Start argument list." },
    "ARG_CLOSE": { "symbol": "⧆⟦", "gloss": "End argument list." },
    "BIND_OPEN": { "symbol": "⧆⟧", "gloss": "Start variable-binding scope." },
    "BIND_CLOSE": { "symbol": "⧆⟨", "gloss": "End variable-binding scope." },
    "SCOPE_PUSH": { "symbol": "⧆⟩", "gloss": "Push nested scope." },
    "SCOPE_POP": { "symbol": "⧆⟪", "gloss": "Pop nested scope." },
    "EVENT_FRAME": { "symbol": "⧆⟫", "gloss": "Start event frame." },
    "STATE_FRAME": { "symbol": "⧆⟬", "gloss": "Start state frame." },
    "ENTITY_FRAME": { "symbol": "⧆⟭", "gloss": "Start entity frame." },
    "REL_FRAME": { "symbol": "⧆⟮", "gloss": "Start relation frame." },
    "FRACTIONAL_SLOT": { "symbol": "⧆⟯", "gloss": "Location where x/y/z fractional encoding is attached." }
  }
}
