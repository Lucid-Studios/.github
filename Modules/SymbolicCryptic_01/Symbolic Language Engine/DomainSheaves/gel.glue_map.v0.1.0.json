{
  "schema": "gel.glue_map.v0.1.0",
  "description": "Cross-domain operator/relation mapping contract for controlled scope permeability.",
  "required": [
    "schema",
    "domains",
    "relation_mappings",
    "operator_mappings",
    "scope_rules"
  ],
  "mapping_types": [
    "equivalent",
    "specialization",
    "causal_overlap"
  ],
  "constraints": {
    "domain_exists_required": true,
    "mapping_identifier_reserved_block": true,
    "specialization_cycles_forbidden": true
  }
}
