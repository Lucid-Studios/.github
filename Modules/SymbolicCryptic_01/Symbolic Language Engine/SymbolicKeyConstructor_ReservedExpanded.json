{
  "symbol_sets": {
    "unicode_basic": {
      "description": "Basic Unicode set including arrows, shapes, and simple glyphs.",
      "range": "U+2190 to U+22FF",
      "examples": [
        "→",
        "∇",
        "⊕",
        "∴"
      ]
    },
    "unicode_extended": {
      "description": "Extended math, technical, and block glyphs.",
      "range": "U+2300 to U+2BFF",
      "examples": [
        "⧖",
        "⥁",
        "⧉",
        "⍙",
        "⧗"
      ]
    },
    "custom_compound": {
      "description": "Compound symbol constructions combining base glyphs.",
      "strategy": "Concatenation of existing symbols to build extended semantics",
      "examples": [
        "⧖∇",
        "⍙⊕",
        "∴⊗"
      ]
    },
    "math_fractional": {
      "description": "Abstract math-based representations for symbolic ratios (P/R/S logic)",
      "encoding": "prefix/root/suffix = x/y/z where each position is fractional representation",
      "examples": [
        "0/1/0",
        "1/0/1",
        "1/1/1"
      ]
    }
  },
  "encoding_format": {
    "notation": "Unicode UTF-8",
    "storage": "Escaped unicode or visual symbol rendering",
    "validation": "All symbols must be unique and decode into prefix-root-suffix components if present."
  },
  "indices": {
    "core": [
      "PrefixIndex",
      "RootIndex",
      "SuffixIndex"
    ],
    "semantic": [
      "OperatorIndex",
      "RelationIndex",
      "GrammarSheafIndex"
    ],
    "reserved": [
      "ReservedIndex"
    ]
  },
  "assignment_rules": {
    "symbol_uniqueness": "No duplicate symbols across PrefixIndex, RootIndex, SuffixIndex, OperatorIndex, RelationIndex, or GrammarSheafIndex unless explicitly allowed in compound class.",
    "fallback_symbol": "@.@",
    "max_assignable_characters": 5120,
    "reserved_enforcement": {
      "mode": "hard_ban",
      "assignment_blocked_in": [
        "PrefixIndex",
        "RootIndex",
        "SuffixIndex",
        "OperatorIndex",
        "RelationIndex",
        "GrammarSheafIndex"
      ],
      "parse_mode": "allow_literals_only",
      "token_scope": "single_character_and_multi_character_tokens"
    },
    "fractional_encoding_usage": {
      "allowed_locations": [
        "sheaf.scope",
        "sheaf.events[].mode",
        "sheaf.states[].confidence"
      ],
      "collision_policy": "fractional values are metadata fields and must never be used as index symbol assignments"
    },
    "reserved": {
      "meta": [
        "⍙",
        "⧖",
        "⊗",
        "⧉"
      ],
      "control": [
        "@",
        "#",
        "~"
      ]
    }
  },
  "Reserved": [
    "!",
    "\"",
    "#",
    "$",
