{
    "schema": "oan.corridor_manifest.v0.1.0",
    "project": {
        "name": "OAN Mortalis Headless Spine",
        "spine": [
            "CradleTek",
            "SoulFrame",
            "AgentiCore"
        ],
        "principles": [
            "LLM proposes; host evaluates and commits",
            "EvaluateIntent is read-only; CommitIntent is the only mutation path",
            "Ledger-driven projection: state changes only by applying events",
            "Anti-swarm: one active AgentiCore per SoulFrame at a time",
            "Determinism: no nondeterministic time/randomness in state transitions",
            "Refusal is explicit: reasonCode + policyVersion always returned"
        ]
    },
    "repo_layout": {
        "src_expected": [
            "Oan.Core",
            "Oan.Runtime",
            "Oan.Ledger",
            "Oan.CradleTek",
            "Oan.SoulFrame",
            "Oan.AgentiCore",
            "Oan.Place.Abstractions",
            "Oan.Place.GEL.Service",
            "Oan.Place.GEL.Self",
            "Oan.Place.OAN.Service",
            "Oan.Place.OAN.Self",
            "Oan.Place.GOA.Service",
            "Oan.Place.GOA.Self",
            "Oan.Host.Api",
            "Oan.Host.Cli"
        ],
        "tests_expected": [
            "Oan.Tests"
        ]
    },
    "corridor": [
        {
            "step": 0,
            "name": "Interconnecting",
            "role": "transport_and_registration",
            "owner": "CradleTek",
            "inputs": [
                "HostConfig",
                "ModuleRegistry",
                "PolicyVersion"
            ],
            "outputs": [
                "RoutingTable",
                "CapabilityCatalog",
                "HostHealth"
            ],
            "forbidden": [
                "WorldStateMutation",
                "EngramWrite",
                "ImplicitAuthority"
            ],
            "done_when": [
                "Host lists modules/actions deterministically",
                "No state mutation occurs during registration",
                "Capability catalog is stable under restart"
            ],
            "tests": [
                "ModuleRegistryTests"
            ]
        },
        {
            "step": 1,
            "name": "SLI Hooks",
            "role": "nl_to_packet",
            "owner": "SoulFrame",
            "inputs": [
                "NaturalLanguage",
                "Provenance",
                "ContextSnapshotId"
            ],
            "outputs": [
                "SliPacket"
            ],
            "forbidden": [
                "TruthClaimsWithoutModality",
                "SilentNormalization",
                "EngramWrite"
            ],
            "done_when": [
                "Encoding is deterministic given same context",
                "Negation/hypothetical preserved as modality",
                "Unknowns yield DEFER not fabricated fills"
            ],
            "tests": [
                "SliDeterminismTests",
                "SliNegationTests"
            ]
        },
        {
            "step": 2,
            "name": "Engram-native IUTT Space",
            "role": "canonical_mapping",
            "owner": "SoulFrame",
            "inputs": [
                "SliPacket",
                "WorldSnapshot",
                "AgentInvariants"
            ],
            "outputs": [
                "CanonicalIntentFrame"
            ],
            "forbidden": [
                "DomainCollapse",
                "ImplicitCommit",
                "NonAuditedRewrite"
            ],
            "done_when": [
                "NL→Canonical→NL is loss-aware and stable",
                "Cross-domain fields do not overwrite each other",
                "Mapping failures produce explicit reason codes"
            ],
            "tests": [
                "IuttMappingRoundTripTests"
            ]
        },
        {
            "step": 3,
            "name": "CradleTek Primary Chambering",
            "role": "session_chamber_init",
            "owner": "CradleTek",
            "inputs": [
                "OperatorAuth",
                "RequestedPlace",
                "AgentRoster"
            ],
            "outputs": [
                "SoulFrameSessionId",
                "ChamberState",
                "InitialSnapshot"
            ],
            "forbidden": [
                "AgentAutonomyWithoutBond",
                "NonDeterministicInit"
            ],
            "done_when": [
                "Chamber can be created without agent action",
                "Ledger partition/tick source fixed at creation",
                "Replay reconstructs identical initial chamber"
            ],
            "tests": [
                "ChamberCreationReplayTests"
            ]
        },
        {
            "step": 4,
            "name": "SoulFrame Access and Governance",
            "role": "permissions_and_gating",
            "owner": "SoulFrame",
            "inputs": [
                "OperatorActions",
                "ActivationRequests",
                "SessionRules"
            ],
            "outputs": [
                "AllowedOrRefused",
                "ActiveAgentProfileId"
            ],
            "forbidden": [
                "MultiActiveAgents",
                "UnloggedActivation",
                "MaskingBypass"
            ],
            "done_when": [
                "Anti-swarm enforced (one active agent)",
                "Activation logged and replayable",
                "Cooldown prevents rapid switching"
            ],
            "tests": [
                "AntiSwarmTests",
                "ActivationReplayTests"
            ]
        },
        {
            "step": 5,
            "name": "AgentiCore ↔ LLM Handshake",
            "role": "bounded_reasoning_surface",
            "owner": "AgentiCore",
            "inputs": [
                "WorldSnapshot",
                "AllowedActions",
                "SessionRules",
                "AgentProfile"
            ],
            "outputs": [
                "IntentProposal",
                "NeedsSpecQuestion",
                "RefusalSuggestion"
            ],
            "forbidden": [
                "DirectWorldMutation",
                "InventedStateClaims",
                "ToolBypass"
            ],
            "done_when": [
                "LLM outputs only structured proposals/questions/refusals",
                "No invented world deltas without commit result",
                "Tool-first behavior stable under missing context"
            ],
            "tests": [
                "LowMindToolObedienceTests"
            ]
        },
        {
            "step": 6,
            "name": "CME Integration (Opal Engram Zipper → CME.Actual)",
            "role": "governed_engram_write",
            "owner": "AgentiCore",
            "inputs": [
                "CommittedEvents",
                "TelemetryDelta",
                "WriteAuthorization"
            ],
            "outputs": [
                "EngramDeltaAppend",
                "UpdatedContinuityIndex"
            ],
            "forbidden": [
                "WriteWithoutAuthorization",
                "OverwriteHistory",
                "UnreplayableEngramState"
            ],
            "done_when": [
                "Engram writes are append-only and governed",
                "Each engram delta links to committed events",
                "Replay yields same continuity index"
            ],
            "tests": [
                "EngramAppendOnlyTests",
                "EngramLinkageTests"
            ]
        },
        {
            "step": 7,
            "name": "Listening Frame + Golden Compass + Telemetry I/O",
            "role": "observation_and_direction",
            "owner": "CradleTek",
            "inputs": [
                "LedgerEvents",
                "SATOutputs",
                "SessionTransitions",
                "ModuleHealth"
            ],
            "outputs": [
                "TelemetryStream",
                "AuditSummaries",
                "ReasonCodeTraces"
            ],
            "forbidden": [
                "TelemetryOverridesAuthority",
                "HiddenDenials",
                "UnversionedPolicy"
            ],
            "done_when": [
                "Refusals always include reasonCode + policyVersion",
                "Drift/anomaly/seal are measurable and logged",
                "Audit reconstruction possible without raw prompt soup"
            ],
            "tests": [
                "TelemetryReasonCodeTests"
            ]
        },
        {
            "step": 8,
            "name": "Enter Ready",
            "role": "armed_governed_state",
            "owner": "CradleTek",
            "inputs": [
                "ChamberInitialized",
                "TelemetryOnline",
                "PolicyConsistent"
            ],
            "outputs": [
                "CME.Ready"
            ],
            "forbidden": [
                "ReadyWithoutGovernance",
                "ReadyWithBrokenReplay"
            ],
            "done_when": [
                "Restart+replay returns to Ready deterministically",
                "Modules report health",
                "Policy version consistent across boundaries"
            ],
            "tests": [
                "ReadyStateReplayTests"
            ]
        },
        {
            "step": 9,
            "name": "Move to CME Idle",
            "role": "closeout_and_holding",
            "owner": "CradleTek",
            "inputs": [
                "CloseoutRequested",
                "InactivityTimeout"
            ],
            "outputs": [
                "Quiesced",
                "SealedReceipt",
                "Folded",
                "SoulFrameCleared"
            ],
            "forbidden": [
                "PostSealCommits",
                "SilentCloseout",
                "IdentityDeletion"
            ],
            "done_when": [
                "Closeout is ledgered: Quiesce→Seal→Fold→Clear",
                "Cradle retains receipt hashes + provenance",
                "Commit refuses after quiesce/seal"
            ],
            "tests": [
                "CloseoutTests",
                "Replay_RestoreCloseoutState"
            ]
        }
    ],
    "next_step": {
        "name": "Implement Closeout Lifecycle",
        "definition_of_done": [
            "Core events: SessionQuiesced, SessionSealed, SessionFolded, SoulFrameCleared",
            "Commit refuses when quiesced/sealed with deterministic reason codes",
            "API endpoint POST /v1/soulframe/{id}/closeout returns receipt",
            "CLI command soulframe closeout returns receipt",
            "Replay test proves deterministic sealed hashes"
        ]
    }
}