(defun find-relations (&key node)
  (let ((target (if (symbolp node) (symbol-name node) node)))
    (remove-if-not
      (lambda (edge)
        (let ((from (getf (cdr edge) :from))
              (to (getf (cdr edge) :to)))
          (or (null target)
              (string-equal from target)
              (string-equal to target))))
      *engram-links*)))
