(defun find-engram (&key concept)
  (let ((target (if (symbolp concept) (symbol-name concept) concept)))
    (remove-if-not
      (lambda (node)
        (let ((value (symbol-name (getf (cdr node) :concept))))
          (or (null target) (string-equal value target))))
      *engram-nodes*)))
